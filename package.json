{
	"name": "kifor-stylelint-config",
	"description": "Stylelint shareable config",
	"version": "1.0.0",
	"exports": "./.stylelintrc.js",
	"files": [
		"./.stylelintrc.js"
	],
	"engines": {
		"node": ">=18.0"
	},
	"type": "commonjs",
	"license": "MIT",
	"author": {
		"name": "Kifor Kostiantyn",
		"email": "kifor.ko@gmail.com"
	},
	"homepage": "https://github.com/kiforks/kifor-stylelint-config#readme",
	"bugs": {
		"url": "https://github.com/kiforks/kifor-stylelint-config/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kiforks/kifor-stylelint-config.git"
	},
	"keywords": [
		"Kifor Kostiantyn",
		"code",
		"quality",
		"style",
		"lint",
		"linter",
		"stylelint",
		"validate",
		"code style",
		"strict",
		"check",
		"checker",
		"enforce",
		"hint",
		"kiforko",
		"kiforks",
		"kskifor",
		"stylelint-config",
		"stylelint config",
		"kifor"
	],
	"devDependencies": {
		"@types/prettier": "^3.0.0",
		"@typescript-eslint/eslint-plugin": "^6.10.0",
		"@typescript-eslint/parser": "^6.10.0",
		"eslint": "^8.53.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-jasmine": "^4.1.3",
		"eslint-plugin-max-params-no-constructor": "^0.0.4",
		"eslint-plugin-prettier": "^5.0.1",
		"gulp": "^4.0.2",
		"gulp-prettier": "^6.0.0",
		"husky": "^8.0.3",
		"lint-staged": "^15.0.2",
		"prettier": "^3.0.3",
		"stylelint": "^15.11.0",
		"stylelint-config-standard": "^34.0.0",
		"stylelint-order": "^6.0.3",
		"ts-node": "^10.9.1",
		"typescript": "^5.2.2"
	},
	"dependencies": {
		"postcss-scss": "^4.0.9"
	},
	"peerDependencies": {
		"stylelint": "~15.11"
	},
	"scripts": {
		"update": "ncu -u",
		"build": "gulp build",
		"watch": "gulp start",
		"fix": "npx stylelint test/**/*.scss --config .stylelintrc.js --fix",
		"lint": "npx eslint 'src/**/*.{ts,html}' --quiet --fix",
		"format": "npx prettier 'src/**/*.{ts,html}' --write"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"*.{js,ts,tsx}": [
			"prettier --check",
			"eslint"
		]
	}
}
